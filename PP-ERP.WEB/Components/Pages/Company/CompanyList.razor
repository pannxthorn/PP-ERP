@page "/company"
@using PP_ERP.DTO.Company
@using PP_ERP.WEB.Services.Company
@inject CompanyService CompanyService
@inject NavigationManager Navigation

<ListPage TValue="RESULT_COMPANY_DTO"
          DataSource="@CompanyDS"
          Title="Company"
          CreateUrl="/company/create"
          IsLoading="@IsLoading">
    <GridColumns>
        <GridColumn HeaderText="Actions" Width="180" TextAlign="Syncfusion.Blazor.Grids.TextAlign.Center">
            <Template>
                @{
                    var item = (context as RESULT_COMPANY_DTO);
                    if (item != null)
                    {
                        <div class="d-flex justify-content-center gap-1">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => _goToView(item.COMPANY_ID)">
                                View
                            </button>
                            <button class="btn btn-sm btn-outline-warning" @onclick="() => _goToEdit(item.COMPANY_ID)">
                                Edit
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => _handleDelete(item.COMPANY_ID)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <polyline points="3 6 5 6 21 6"></polyline>
                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                </svg>
                            </button>
                        </div>
                    }
                }
            </Template>
        </GridColumn>
        <GridColumn Field="@nameof(RESULT_COMPANY_DTO.COMPANY_CODE)" HeaderText="Code" Width="150"></GridColumn>
        <GridColumn Field="@nameof(RESULT_COMPANY_DTO.COMPANY_NAME)" HeaderText="Company Name" Width="250"></GridColumn>
        <GridColumn Field="@nameof(RESULT_COMPANY_DTO.TAX_NO)" HeaderText="Tax No." Width="150"></GridColumn>
        <GridColumn Field="@nameof(RESULT_COMPANY_DTO.PHONE)" HeaderText="Phone" Width="150"></GridColumn>
        <GridColumn Field="@nameof(RESULT_COMPANY_DTO.EMAIL)" HeaderText="Email" Width="200"></GridColumn>
    </GridColumns>
</ListPage>

@code
{
    public List<RESULT_COMPANY_DTO> CompanyDS { get; set; } = new List<RESULT_COMPANY_DTO>();
    public bool IsLoading { get; set; } = true;

    protected override async Task OnInitializedAsync()
    {
        IsLoading = true;
        var response = await CompanyService.GetAllCompany();
        if (response.IS_SUCCESS && response.DATA != null)
        {
            CompanyDS = response.DATA;
        }
        IsLoading = false;
    }

    private void _goToView(int id) => Navigation.NavigateTo($"/company/{id}");
    private void _goToEdit(int id) => Navigation.NavigateTo($"/company/{id}/edit");

    private async Task _handleDelete(int id)
    {
        var response = await CompanyService.DeleteCompany(id);
        if (response.IS_SUCCESS)
        {
            CompanyDS = CompanyDS.Where(x => x.COMPANY_ID != id).ToList();
        }
    }
}
