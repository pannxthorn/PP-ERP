@namespace PP_ERP.WEB.Components.Layout
@using PP_ERP.DTO.Enums

<!-- Header -->
<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex align-items-center gap-3">
        <button class="info-back-btn" @onclick="OnBackClicked">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="19" y1="12" x2="5" y2="12"></line>
                <polyline points="12 19 5 12 12 5"></polyline>
            </svg>
        </button>
        <div>
            <h5 class="mb-0 fw-semibold" style="color: #1a1a2e;">@Title</h5>
            @if (!string.IsNullOrEmpty(Breadcrumb))
            {
                <small style="color: #a0a0b0; font-size: 0.78rem;">@Breadcrumb</small>
            }
        </div>
    </div>
    <div class="d-flex gap-2">
        @if (ToolbarContent != null)
        {
            @ToolbarContent
        }
        else
        {
            @if (Mode == PageMode.View)
            {
                <button class="info-btn info-btn-edit" @onclick="OnEditClicked">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                    Edit
                </button>
            }
            @if (Mode == PageMode.Create || Mode == PageMode.Edit)
            {
                <button class="info-btn info-btn-save" @onclick="OnSaveClicked">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                        <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                    Save
                </button>
            }
            <button class="info-btn info-btn-close" @onclick="OnBackClicked">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="me-1">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
                Close
            </button>
        }
    </div>
</div>

<!-- Status Bar -->
<div class="info-status-bar mb-4">
    <div class="d-flex align-items-center gap-2">
        <span style="font-weight: 500; color: #1a1a2e;">Info</span>
        <span style="color: #d0d0d8;">|</span>
        <span style="color: #a0a0b0;">Status</span>
        @if (StatusContent != null)
        {
            @StatusContent
        }
        else
        {
            <span class="info-mode-badge info-mode-@Mode.ToString().ToLower()">
                @Mode.ToString()
            </span>
        }
    </div>
</div>

<!-- Tab Navigation -->
@if (TabContent != null)
{
    <div class="info-tab-bar mb-4">
        @TabContent
    </div>
}

<!-- Body -->
@if (IsLoading)
{
    <div class="d-flex justify-content-center align-items-center py-5">
        <div class="spinner-border" style="color: #6c63ff;" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    @if (ChildContent != null)
    {
        @ChildContent
    }
}

@code
{
    [Parameter] public string Title { get; set; } = "Info";
    [Parameter] public string? Breadcrumb { get; set; }
    [Parameter] public PageMode Mode { get; set; } = PageMode.Create;
    [Parameter] public bool IsLoading { get; set; } = false;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? ToolbarContent { get; set; }
    [Parameter] public RenderFragment? TabContent { get; set; }
    [Parameter] public RenderFragment? StatusContent { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnEdit { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }
    [Parameter] public EventCallback OnBack { get; set; }

    public bool IsReadOnly => Mode == PageMode.View;

    private async Task OnSaveClicked() => await OnSave.InvokeAsync();
    private async Task OnEditClicked() => await OnEdit.InvokeAsync();
    private async Task OnDeleteClicked() => await OnDelete.InvokeAsync();
    private async Task OnBackClicked() => await OnBack.InvokeAsync();
}
