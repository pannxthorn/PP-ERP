@namespace PP_ERP.WEB.Components.Layout
@typeparam TValue

<div class="card">
    <div class="card-header">
        <div class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                 class="title-icon">
                <rect x="3" y="3" width="7" height="7"></rect>
                <rect x="14" y="3" width="7" height="7"></rect>
                <rect x="3" y="14" width="7" height="7"></rect>
                <rect x="14" y="14" width="7" height="7"></rect>
            </svg>
            <h3>@Title</h3>
        </div>
        <div class="card-toolbar">
            @if (ToolbarContent != null)
            {
                @ToolbarContent
            }
            else if (!string.IsNullOrEmpty(CreateUrl))
            {
                <a href="@CreateUrl" class="btn btn-sm btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                         style="margin-right: 0.35rem;">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Add New
                </a>
            }
        </div>
    </div>
    <div class="card-body">
        <SfGrid DataSource="@DataSource"
                AllowPaging="@AllowPaging"
                AllowSorting="@AllowSorting"
                AllowFiltering="@AllowFiltering"
                AllowTextWrap="true">
            <GridPageSettings PageSize="@PageSize" PageSizes="new object[] {10, 50}"></GridPageSettings>
            @if (ChildContent != null)
            {
                @ChildContent
            }
        </SfGrid>
    </div>
</div>

@code
{
    [Parameter] public List<TValue> DataSource { get; set; } = new List<TValue>();
    [Parameter] public string Title { get; set; } = "List";
    [Parameter] public string? CreateUrl { get; set; }
    [Parameter] public bool AllowPaging { get; set; } = true;
    [Parameter] public bool AllowSorting { get; set; } = true;
    [Parameter] public bool AllowFiltering { get; set; } = true;
    [Parameter] public int PageSize { get; set; } = 10;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? ToolbarContent { get; set; }

    // private object PageSizeOptions { get; set; } = new object[] { 10, 20, 50, 100 };
}
