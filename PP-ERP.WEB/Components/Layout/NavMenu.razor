<div class="sidebar-brand">
    <div class="brand-logo">
        <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="28" height="28" rx="8" fill="#009ef7"/>
            <path d="M8 9h5v5H8V9zm7 0h5v5h-5V9zm-7 7h5v5H8v-5zm7 2.5a2.5 2.5 0 1 1 5 0 2.5 2.5 0 0 1-5 0z" fill="white"/>
        </svg>
        <span class="brand-text">PP-ERP</span>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="sidebar-nav">
        <div class="nav-section-label">Menu</div>

        <div class="nav-item">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </span>
                <span class="nav-text">Home</span>
            </NavLink>
        </div>

        <div class="nav-item-group">
            <button class="nav-group-toggle @(_orgExpanded ? "expanded" : "")" @onclick="_toggleOrg">
                <span class="nav-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </span>
                <span class="nav-text">Organization</span>
                <span class="nav-arrow">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </span>
            </button>

            @if (_orgExpanded)
            {
                <div class="nav-sub-menu">
                    <div class="nav-item">
                        <NavLink class="nav-link" href="company">
                            <span class="nav-text">Company</span>
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="branch">
                            <span class="nav-text">Branch</span>
                        </NavLink>
                    </div>
                </div>
            }
        </div>
        <div class="nav-item-group">
            <button class="nav-group-toggle @(_userExpanded ? "expanded" : "")" @onclick="_toggleUser">
                <span class="nav-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                        <circle cx="12" cy="7" r="4"/>
                    </svg>
                </span>
                <span class="nav-text">User Management</span>
                <span class="nav-arrow">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                </span>
            </button>

            @if (_userExpanded)
            {
                <div class="nav-sub-menu">
                    <div class="nav-item">
                        <NavLink class="nav-link" href="user">
                            <span class="nav-text">User</span>
                        </NavLink>
                    </div>
                    <div class="nav-item">
                        <NavLink class="nav-link" href="role">
                            <span class="nav-text">Role & Permission</span>
                        </NavLink>
                    </div>
                </div>
            }
        </div>
    </nav>
</div>

@code
{
    private bool _orgExpanded = true;
    private bool _userExpanded = true;

    private void _toggleOrg() => _orgExpanded = !_orgExpanded;
    private void _toggleUser() => _userExpanded = !_userExpanded;
}
